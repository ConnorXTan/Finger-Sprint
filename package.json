{
  "name": "finger-sprint",
  "version": "0.1.0",
  "private": true,
  "description": "Webcam finger-speed running game — clean frontend/backend split.",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev -w @finger-sprint/backend",
    "dev:frontend": "npm run dev -w @finger-sprint/frontend",
    "typecheck": "npm run typecheck -w @finger-sprint/backend && npm run typecheck -w @finger-sprint/frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build -w @finger-sprint/frontend"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "concurrently": "^10.0.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.10"
  }
}
